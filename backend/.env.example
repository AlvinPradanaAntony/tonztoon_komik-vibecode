# Tonztoon Komik Backend
# Copy this file to `.env` and adjust the values for your environment.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=true

# ---------------------------------------------------------------------------
# Database
# Use direct Postgres connection string for backend server access.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tonztoon_komik

# ---------------------------------------------------------------------------
# Supabase Auth
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx_or_legacy_anon_key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx_or_legacy_service_role_key
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1

# Optional fallback for legacy HS256 projects.
SUPABASE_JWT_SECRET=

# Optional email confirmation redirect deep-link.
SUPABASE_AUTH_REDIRECT_URL=myapp://auth/callback

# Local-only fallback for old testing flow. Keep false in shared/dev/prod envs.
ALLOW_DEV_USER_HEADER=false

# ---------------------------------------------------------------------------
# GitHub API (manual scraper trigger)
# ---------------------------------------------------------------------------
GITHUB_PAT=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=tonztoon_komik
GITHUB_WORKFLOW_FILE=scraper.yml
