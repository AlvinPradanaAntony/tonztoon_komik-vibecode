# ============================================
# Tonztoon Komik — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/tonztoon_komik

# --- GitHub API (for workflow_dispatch manual sync) ---
GITHUB_PAT=ghp_your_personal_access_token_here
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=tonztoon_komik
GITHUB_WORKFLOW_FILE=scraper.yml

# --- App Settings ---
APP_ENV=development
APP_DEBUG=true
